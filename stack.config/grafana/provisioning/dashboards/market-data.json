    {
      "id": 4,
      "type": "stat",
      "title": "Asia",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "market_data_latest_value{region=\"asia\"}",
          "legendFormat": "{{source}} / {{label}}"
        }
      ],
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 7},
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
