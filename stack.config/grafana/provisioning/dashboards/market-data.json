          "refId": "A",
          "expr": "market_data_latest_value{region=\"united_states\"}",
          "legendFormat": "{{source}} / {{label}}"
        }
      ],
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 7},
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Global + Crypto",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "market_data_latest_value{region=~\"global|crypto\"}",
          "legendFormat": "{{region}} / {{label}}"
        }
      ],
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 7},
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Regional Move Percent",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "market_data_daily_change_percent",
          "legendFormat": "{{region}} / {{label}}"
        }
      ],
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 14},
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0},
              {"color": "green", "value": 0.01}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Regional Values Over Time",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "market_data_latest_value",
          "legendFormat": "{{region}} / {{label}}"
        }
      ],
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 23},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Source Freshness",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "market_data_source_up",
          "legendFormat": "{{region}} / {{source}} / {{label}}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "market_data_reported_timestamp_seconds",
          "legendFormat": "{{region}} / {{source}} / {{label}}",
          "format": "table",
          "instant": true
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 33},
      "options": {"showHeader": true},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "inspect": false}},
        "overrides": []
      }
    }
  ]
}

