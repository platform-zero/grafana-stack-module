{
  "id": null,
  "uid": "market-data",
  "title": "Daily Market Data",
  "tags": ["markets", "daily", "external-data"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "6h",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Australia",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "market_data_latest_value{region=\"australia\"}",
          "legendFormat": "{{source}} / {{label}}"
        }
      ],
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "China",
