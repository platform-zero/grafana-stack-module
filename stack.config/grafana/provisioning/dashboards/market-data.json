        {
          "refId": "A",
          "expr": "market_data_latest_value{region=\"europe\"}",
          "legendFormat": "{{source}} / {{label}}"
        }
      ],
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 0},
      "options": {
