{
  "uid": "account-service-usage",
  "title": "Account Service Usage",
  "tags": ["usage", "accounts", "keycloak", "caddy", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Forward-Auth Requests by Account and Service",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (auth_user, service) (count_over_time({container=\"caddy\"} | json | auth_user != \"\" | label_format auth_user=\"{{.auth_user}}\", service=\"{{.service}}\" [$__interval]))",
          "legendFormat": "{{auth_user}} / {{service}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top Forward-Auth Account/Service Pairs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(25, sum by (auth_user, service) (count_over_time({container=\"caddy\"} | json | auth_user != \"\" | label_format auth_user=\"{{.auth_user}}\", service=\"{{.service}}\" [$__range])))",
          "legendFormat": "{{auth_user}} / {{service}}",
          "instant": true
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "OIDC Sign-Ins by Account and Client",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(25, sum by (username, client_id) (count_over_time({container=\"keycloak\"} |= \"LOGIN\" | json | username != \"\" | client_id != \"\" | label_format username=\"{{.username}}\", client_id=\"{{.client_id}}\" [$__range])))",
          "legendFormat": "{{username}} / {{client_id}}",
          "instant": true
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Account Activity Events",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=\"caddy\"} | json | auth_user != \"\"",
          "legendFormat": "caddy"
        },
        {
          "refId": "B",
          "expr": "{container=\"keycloak\"} |= \"LOGIN\"",
          "legendFormat": "keycloak"
        }
      ],
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    }
  ]
}
